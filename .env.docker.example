# 宿主机仓库根目录。Compose 只把它挂载到容器内的 /repositories，不写入镜像。
GETLATESTREPO_SCAN_ROOT=/absolute/path/to/repositories

# Linux 建议填写 `id -u` / `id -g`，确保容器能够更新宿主机仓库。
GETLATESTREPO_UID=1000
GETLATESTREPO_GID=1000

# 可选：包含 known_hosts 与 SSH 私钥的目录，默认使用当前用户 ~/.ssh。
GETLATESTREPO_SSH_DIR=${HOME}/.ssh

# Docker 容器通过宿主机网关访问本机 7890，不能使用容器自身的 127.0.0.1。
GETLATESTREPO_PROXY_URL=http://host.docker.internal:7890
